# Formspree — отправка заявок на email
# Все заявки направляются на uhomegrodno@gmail.com
#
# Настройка:
# 1. Зайдите на https://formspree.io и войдите/зарегистрируйтесь
# 2. Создайте новую форму (или используйте одну для всех)
# 3. В настройках формы укажите email для уведомлений: uhomegrodno@gmail.com
# 4. Скопируйте ID формы (часть после /f/ в URL, например: xyzabcde)
# 5. Вставьте ниже и переименуйте файл в .env.local

# Форма обратной связи (страница Контакты)
NEXT_PUBLIC_FORMSPREE_CONTACTS=

# Форма «Заказать звонок» (главная страница)
# Можно использовать тот же ID, что и выше
NEXT_PUBLIC_FORMSPREE_CTA=

# Квиз (подбор решения)
# Можно использовать тот же ID, что и CTA
NEXT_PUBLIC_FORMSPREE_QUIZ=

# Instagram — лента постов на главной
# Вариант 1: Виджет Elfsight (embedsocial, elfsight.com) — без кода
NEXT_PUBLIC_INSTAGRAM_EMBED_ID=
# Вариант 2: Instagram Graph API (Business/Creator аккаунт)
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_USER_ID=
# Ссылка на профиль (для кнопки «Подписаться»)
NEXT_PUBLIC_INSTAGRAM_URL=
